# ============================================================
# gateway, platform configuration for this setting.
# ------------------------------------------------------------
# Optional configuration for this setting.
# Configuration note for this setting.
# Default configuration for this setting.
# Sensitive configuration for this setting; use a securely generated environment-specific value.
# LightRAG, RAG configuration for ENV.
# ============================================================

# ============================================================
# Configuration note for ENV.
# ============================================================
# Configuration note for ENV.
ENV=dev
LOG_LEVEL=INFO
# Configuration note for WORKERS.
WORKERS=4

# ============================================================
# PostgreSQL, database configuration for DB HOST.
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=jonex
DB_PASSWORD=CHANGE_ME
DB_NAME=jonex

# ============================================================
# Cache configuration for REDIS URL.
# ============================================================
REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=your_redis_password

# ============================================================
# Service dependency and startup ordering for MILVUS HOST.
# ============================================================
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_HTTP_PORT=9091
# Required configuration for MINIO ADDRESS; provide an environment-specific value.
MINIO_ADDRESS=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
# Milvus, etcd configuration for ETCD ENDPOINTS.
ETCD_ENDPOINTS=etcd:2379

# ============================================================
# database, Neo4j, ontology configuration for NEO4J PASSWORD.
# ============================================================
# Sensitive configuration for NEO4J PASSWORD; use a securely generated environment-specific value.
NEO4J_PASSWORD=CHANGE_ME
# NEO4J_HEAP=1G
# NEO4J_PAGECACHE=512M

# ============================================================
# security configuration for JWT SECRET.
# ============================================================
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ============================================================
# authentication configuration for LOGIN TICKET EXPIRE SECONDS.
# ============================================================
# Default configuration for LOGIN TICKET EXPIRE SECONDS.
LOGIN_TICKET_EXPIRE_SECONDS=60
# Configuration note for AUTH ALLOWED REDIRECT URIS.
# Development-only configuration for AUTH ALLOWED REDIRECT URIS.
# AUTH_ALLOWED_REDIRECT_URIS={"core-business":["http://localhost:5175/"],"platform-management":["http://localhost:5177/"],"ecosystem-management":["http://localhost:5176/"]}
# Configuration note for AUTH ALLOWED REDIRECT URIS.
# AUTH_ALLOWED_REDIRECT_URIS={"core-business":["https://core.jonex.com/"],"platform-management":["https://platform.jonex.com/"],"ecosystem-management":["https://ecosystem.jonex.com/"]}
AUTH_ALLOWED_REDIRECT_URIS={}
# Default configuration for AUTH CORS ORIGINS.
# AUTH_CORS_ORIGINS=https://shell.jonex.com,https://core.jonex.com
AUTH_CORS_ORIGINS=
# Configuration note for this setting.
# AUTH_COOKIE_DOMAIN=.jonex.com
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=Lax

# ============================================================
# frontend configuration for FRONTEND PORT.
# ============================================================
# Default configuration for FRONTEND PORT.
FRONTEND_PORT=80
# Default configuration for FRONTEND API BASE URL.
FRONTEND_API_BASE_URL=/api
# Configuration note for VITE ALLOWED REDIRECT ORIGINS.
# See http://localhost:5175,http://localhost:5177,http://localhost:5176.
VITE_ALLOWED_REDIRECT_ORIGINS=

# KNOWLEDGE_BASE_URL=http://knowledge-base-service:8000
# BUSINESS_DOMAIN_URL=http://business-domain-service:8000
# PLATFORM_URL=http://platform-service:8000
# ATOMIC_RAG_URL=http://atomic-rag:8000
# SIDECAR_URL=http://sidecar:8000
# Required shared secret for Gateway and internal clients calling Sidecar.
SIDECAR_API_KEY=CHANGE_ME

# ============================================================
# LLM, embedding configuration for LLMGW UPSTREAM LLM HOST.
# ============================================================
# Sensitive configuration for LLMGW UPSTREAM LLM HOST; use a securely generated environment-specific value.
LLMGW_UPSTREAM_LLM_HOST=https://tokenhub.tencentmaas.com/v1
# Required configuration for LLMGW UPSTREAM LLM API KEY; provide an environment-specific value.
LLMGW_UPSTREAM_LLM_API_KEY=your_upstream_llm_api_key_here
# Default configuration for LLMGW UPSTREAM EMBED HOST.
LLMGW_UPSTREAM_EMBED_HOST=http://host.docker.internal:11434/v1
LLMGW_UPSTREAM_EMBED_API_KEY=ollama
# ===== reranking, RAG configuration for LLMGW RERANK BINDING =====
# reranking configuration for LLMGW RERANK BINDING.
# LLM, reranking configuration for LLMGW RERANK BINDING.
LLMGW_RERANK_BINDING=ollama-generate
LLMGW_RERANK_MODEL=awenleven/Qwen3-Reranker-4B:Q4_K_M
LLMGW_UPSTREAM_RERANK_HOST=http://host.docker.internal:11434
LLMGW_UPSTREAM_RERANK_API_KEY=ollama
# model configuration for LLMGW RERANK PROMPT PROFILE.
LLMGW_RERANK_PROMPT_PROFILE=qwen3
LLMGW_RERANK_MAX_DOCS=12
LLMGW_RERANK_CONCURRENCY=4
LLMGW_RERANK_TIMEOUT=30
# Sensitive configuration for LLMGW INTERNAL TOKENS; use a securely generated environment-specific value.
LLMGW_INTERNAL_TOKENS=CHANGE_ME_LIGHTRAG,CHANGE_ME_PLATFORM
# Configuration note for LLMGW METERING ENABLED.
LLMGW_METERING_ENABLED=true
LLMGW_PG_FLUSH_MAX_ROWS=20
# ===== Embedding aggregation configuration =====
# embedding configuration for LLMGW EMBED AGGREGATE ENABLED.
# Default configuration for LLMGW EMBED AGGREGATE ENABLED.
LLMGW_EMBED_AGGREGATE_ENABLED=true  # Configuration note for LLMGW EMBED AGGREGATE SCENES.
LLMGW_EMBED_AGGREGATE_SCENES=lightrag_embed,ontology_embed  # Configuration note for this setting.
# ===== Configuration note for LLMGW DISABLE THINKING ENABLED =====
# Sensitive configuration for LLMGW DISABLE THINKING ENABLED; use a securely generated environment-specific value.
# LLM configuration for LLMGW DISABLE THINKING ENABLED.
# LLM configuration for LLMGW DISABLE THINKING ENABLED.
# LLM configuration for LLMGW DISABLE THINKING ENABLED.
# Proxy and routing configuration for LLMGW DISABLE THINKING ENABLED.
# LLM, ontology configuration for LLMGW DISABLE THINKING ENABLED.
LLMGW_DISABLE_THINKING_ENABLED=true  # Configuration note for LLMGW DISABLE THINKING MODELS.
LLMGW_DISABLE_THINKING_MODELS=deepseek-v4-flash-202605  # model configuration for LLMGW DISABLE THINKING SCENES.
LLMGW_DISABLE_THINKING_SCENES=lightrag_extract,ontology_extract  # Configuration note for this setting.

