RERANK_BINDING_API_KEY=CHANGE_ME_LIGHTRAG
# RERANK_MODEL=awenleven/Qwen3-Reranker-4B:Q4_K_M
# reranking, RAG configuration for this setting.
# RAG_RETRIEVAL_RERANK_ENABLED=false
# embedding configuration for this setting.
# ONTOLOGY_EMBED_DESC_MAXLEN=300
# Cache configuration for this setting.
# ONTOLOGY_QUERY_EMBED_TTL=300
# Cache configuration for this setting.
# ONTOLOGY_QUERY_EMBED_CACHE_MAX=500
# Default configuration for this setting.
# embedding, ontology configuration for this setting.
# Configuration note for EMBEDDING DIM.
# ONTOLOGY_EMBED_TIMEOUT=5
# Default configuration for EMBEDDING DIM.
# Configuration note for EMBEDDING DIM.
# ONTOLOGY_EMBED_MAX_RETRIES=1
# embedding, LightRAG, RAG configuration for EMBEDDING DIM.
# Neo4j, embedding configuration for EMBEDDING DIM.
EMBEDDING_DIM=1024
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_BINDING_HOST=http://llm-gateway:8787/v1
# embedding, LightRAG, RAG configuration for EMBEDDING SEND DIM.
# Configuration note for EMBEDDING SEND DIM.
# Configuration note for EMBEDDING SEND DIM.
# Send embedding dimensions only when the upstream provider supports it.
EMBEDDING_SEND_DIM=false
EMBEDDING_BINDING_API_KEY=CHANGE_ME_LIGHTRAG
# Default configuration for LLM BINDING API KEY FOR ONTOLOGY.
# REASONING_TRACE_ENABLED=true
# Sensitive configuration for LLM BINDING API KEY FOR ONTOLOGY; use a securely generated environment-specific value.
LLM_BINDING_API_KEY_FOR_ONTOLOGY=CHANGE_ME_LIGHTRAG

