# ============================================================
# LightRAG, RAG configuration for this setting.
# ------------------------------------------------------------
# Optional configuration for this setting.
# Default configuration for this setting.
# Optional configuration for HOST.
#   Reference/LightRAG/env.example
# ============================================================

# ============================================================
# Configuration note for HOST.
# ============================================================
HOST=0.0.0.0
PORT=9621
WORKERS=2
TIMEOUT=300

# ============================================================
# LightRAG, RAG configuration for LIGHTRAG API KEY.
# ============================================================
LIGHTRAG_API_KEY=change-me-in-production-please
# Development-only configuration for AUTH ACCOUNTS.
AUTH_ACCOUNTS=admin:change-me-please
TOKEN_SECRET=change-me-jwt-secret
TOKEN_EXPIRE_HOURS=48

# ============================================================
# Path configuration for WORKING DIR.
# ============================================================
WORKING_DIR=/app/data/rag_storage
INPUT_DIR=/app/data/inputs

# ============================================================
# Proxy and routing configuration for LLM BINDING.
# ============================================================
LLM_BINDING=openai
LLM_BINDING_HOST=http://llm-gateway:8787/v1
LLM_BINDING_API_KEY=CHANGE_ME_LIGHTRAG
LLM_MODEL=deepseek-v4-flash-202605
LLM_TIMEOUT=600
# Configuration note for this setting.
# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://host.docker.internal:11434
# LLM_MODEL=qwen3.5:9b
# OLLAMA_LLM_NUM_CTX=32768
# OLLAMA_LLM_ENABLE_THINK=false

# ============================================================
# Proxy and routing configuration for EMBEDDING BINDING.
# embedding configuration for EMBEDDING BINDING.
# ============================================================
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://llm-gateway:8787/v1
EMBEDDING_BINDING_API_KEY=CHANGE_ME_LIGHTRAG
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_DIM=1024
EMBEDDING_SEND_DIM=true
EMBEDDING_TOKEN_LIMIT=8192

# ------------------------------------------------------------
# See scripts/bench_embedding.py.
# ------------------------------------------------------------
# Default configuration for EMBEDDING FUNC MAX ASYNC.
# Default configuration for EMBEDDING FUNC MAX ASYNC.
# embedding, platform configuration for EMBEDDING FUNC MAX ASYNC.
# embedding configuration for EMBEDDING FUNC MAX ASYNC.
EMBEDDING_FUNC_MAX_ASYNC=16
EMBEDDING_BATCH_NUM=4

# ============================================================
# backend, storage configuration for this setting.
# PostgreSQL, Neo4j, Milvus configuration for this setting.
# Configuration note for this setting.
#
# Service dependency and startup ordering for LIGHTRAG KV STORAGE.
# PostgreSQL, Milvus configuration for LIGHTRAG KV STORAGE.
# PostgreSQL, LightRAG, RAG configuration for LIGHTRAG KV STORAGE.
# Milvus configuration for LIGHTRAG KV STORAGE.
# Create the required runtime resource.
# ============================================================
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
# Service dependency and startup ordering for LIGHTRAG GRAPH STORAGE.
# LightRAG, RAG, ontology configuration for LIGHTRAG GRAPH STORAGE.
# Service dependency and startup ordering for LIGHTRAG GRAPH STORAGE.
# ontology, backend, storage configuration for LIGHTRAG GRAPH STORAGE.
# Neo4j, backend configuration for LIGHTRAG GRAPH STORAGE.
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

# ------------------------------------------------------------
# PostgreSQL, RAG configuration for POSTGRES HOST.
# Sensitive configuration for POSTGRES HOST; use a securely generated environment-specific value.
# LightRAG, RAG configuration for POSTGRES HOST.
# ------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=jonex
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DATABASE=jonex
POSTGRES_MAX_CONNECTIONS=25

# ------------------------------------------------------------
# Milvus, RAG configuration for MILVUS URI.
# Milvus configuration for MILVUS URI.
# Create the required runtime resource.
# ------------------------------------------------------------
MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=lightrag
# MILVUS_USER=
# MILVUS_PASSWORD=
# MILVUS_TOKEN=

# Optional configuration for this setting.
# LIGHTRAG_KV_STORAGE=JsonKVStorage
# LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
