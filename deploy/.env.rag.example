# Neo4j configuration for NEO4J MAX CONNECTION POOL SIZE.
# Service dependency and startup ordering for NEO4J MAX CONNECTION POOL SIZE.
NEO4J_MAX_CONNECTION_POOL_SIZE=16

# ============================================================
# Configuration note for SUMMARY LANGUAGE.
# ============================================================
SUMMARY_LANGUAGE=Chinese
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100

