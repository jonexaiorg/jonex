# Version control and local tooling
.git/
.gitignore
.gitattributes
.github/
.vscode/
.idea/
.kiro/
.claude/
.agents/
.worktrees/

# Secrets and local runtime configuration
**/.env
**/.env.*
*.local.yaml
*.local.yml
capability_runtime.local.yaml

# Python caches, environments, tests, and build output
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.egg-info/
*.so
.venv/
.venv-*/
venv/
env/
**/.venv/
**/venv/
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
**/.mypy_cache/
.ruff_cache/
**/.ruff_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
build/
dist/
site/
tests/
test-results/

# Frontend dependencies and output
**/node_modules/
frontends/**/dist/
frontends/**/dist-ssr/
frontends/**/.vite/
frontends/**/.turbo/
frontends/**/coverage/
frontends/**/package-lock.json
frontends/**/yarn.lock
frontends/**/_legacy/

# Logs, runtime data, and generated storage
logs/
log/
.dev-logs/
frontends/.dev-logs/
*.log
*.log.*
data/
inputs/
output/
rag_storage/
.lightrag_data/
local_neo4jWorkDir/
neo4jWorkDir/
