# ============================================================
# LightRAG Server 配置 —— 仅 lightrag 容器加载（实际值）
# ------------------------------------------------------------
# 段落结构与 .env.rag.example 一致。完整可选项参见上游参考：
#   Reference/LightRAG/env.example
# ============================================================

# ============================================================
# 1. 服务
# ============================================================
HOST=0.0.0.0
PORT=9621
WORKERS=2
TIMEOUT=300

# ============================================================
# 2. 鉴权（atomic-rag 调用时附 X-API-Key；须与 .env 的 LIGHTRAG_API_KEY 一致）
# ============================================================
LIGHTRAG_API_KEY=change-me-in-production-please
# WebUI 登录（仅开发/运维使用，生产不暴露）
AUTH_ACCOUNTS=admin:change-me-please
TOKEN_SECRET=change-me-jwt-secret
TOKEN_EXPIRE_HOURS=48

# ============================================================
# 3. 工作目录
# ============================================================
WORKING_DIR=.lightrag_data/rag_storage
INPUT_DIR=.lightrag_data/inputs

# ============================================================
# 4. LLM（OpenAI 兼容协议，经 llm-gateway 代理；不直连上游）
# ============================================================
LLM_BINDING=openai
LLM_BINDING_HOST=http://127.0.0.1:8787/v1
LLM_BINDING_API_KEY=CHANGE_ME_LIGHTRAG
LLM_MODEL=deepseek-v4-flash-202605
LLM_TIMEOUT=600

# ============================================================
# 5. Embedding（OpenAI 兼容协议，经 llm-gateway 代理）
# ============================================================
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://127.0.0.1:8787/v1
EMBEDDING_BINDING_API_KEY=CHANGE_ME_LIGHTRAG
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_DIM=1024
EMBEDDING_SEND_DIM=true
EMBEDDING_TOKEN_LIMIT=8192

# ============================================================
# 6. 存储后端
#    已升级：KV/DocStatus 落 PostgreSQL；图谱用 Neo4j；向量用 Milvus。
#    本地调试连接指向 127.0.0.1（须先 make dev-deps-up 起 postgres/milvus）。
#    PG 端向量走 Milvus，故 enable_vector 自动为 False，无需 pgvector 扩展；
#    Milvus 库不存在时由 LightRAG 自动创建。
#    如需退回单进程最简实现（仅本地）：把三项改回 JsonKVStorage /
#    JsonDocStatusStorage / NanoVectorDBStorage 即可。
# ============================================================
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
# ⚠️ 硬依赖：图存储必须为 Neo4JStorage。atomic-rag 的存储读取（get_storage_* /
#    本体抽取）经 lightrag-server 新增端点 GET /graph/{entities,relationships,counts,summary}
#    读图数据，这些端点依赖 Neo4JStorage 的 jonex_* 图查询方法（见 JONEX_CHANGES.md 九）。
#    换其它图后端（NetworkX/PGGraph/Memgraph 等）会因缺该方法返回 HTTP 501、存储读与本体
#    抽取失效。KV/DocStatus/Vector 后端可随意（新接口不读本地 JSON），但图必须 Neo4j。
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

# PostgreSQL 连接（PGKVStorage / PGDocStatusStorage 用）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=jonex
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DATABASE=jonex
POSTGRES_MAX_CONNECTIONS=25

# Milvus 连接（MilvusVectorDBStorage 用）
MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB_NAME=lightrag

# ============================================================
# 7. Neo4j 图后端（LightRAG 图谱存储）
# ============================================================
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ============================================================
# 8. 文档处理
# ============================================================
SUMMARY_LANGUAGE=Chinese
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100

# ============================================================
# 9. 并发控制
# ============================================================
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2

# ============================================================
# 10. LLM 缓存
# ============================================================
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
