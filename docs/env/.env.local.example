# ============================================================
# gateway, platform configuration for this setting.
# ------------------------------------------------------------
# Configuration note for this setting.
# Default configuration for FRONTEND PORT.
# ============================================================

# ============================================================
# frontend configuration for FRONTEND PORT.
# ============================================================
# Default configuration for FRONTEND PORT.
FRONTEND_PORT=80
# Default configuration for FRONTEND API BASE URL.
FRONTEND_API_BASE_URL=http://127.0.0.1:8000
AUTH_ALLOWED_REDIRECT_URIS={"core-business":["http://localhost:5175/","http://localhost:8080/core-business/"],"platform-management":["http://localhost:5177/","http://localhost:8080/platform-management/"],"ecosystem-management":["http://localhost:5176/","http://localhost:8080/ecosystem-management/"}
# Configuration note for VITE ALLOWED REDIRECT ORIGINS.
# See http://localhost:5175,http://localhost:5176,http://localhost:5177.
VITE_ALLOWED_REDIRECT_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:5175,http://localhost:5176,http://localhost:5177

# ============================================================
# Configuration note for LOG LEVEL.
# ============================================================
LOG_LEVEL=INFO
WORKERS=4

# ============================================================
# PostgreSQL, database configuration for DB HOST.
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=jonex
DB_PASSWORD=CHANGE_ME
DB_NAME=jonex

# ============================================================
# Cache configuration for REDIS URL.
# ============================================================
REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_PASSWORD=your_redis_password

# ============================================================
# Service dependency and startup ordering for MILVUS HOST.
# ============================================================
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_HTTP_PORT=9091
# MinIO, Milvus, object storage configuration for MINIO ADDRESS.
MINIO_ADDRESS=127.0.0.1:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
# Milvus, etcd configuration for ETCD ENDPOINTS.
ETCD_ENDPOINTS=127.0.0.1:2379

# ============================================================
# Sensitive configuration for JWT SECRET; use a securely generated environment-specific value.
# ============================================================
# NEO4J_PASSWORD=CHANGE_ME

# ============================================================
# security configuration for JWT SECRET.
# ============================================================
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ============================================================
# Default configuration for this setting.
# ============================================================
# LOGIN_TICKET_EXPIRE_SECONDS=60
# AUTH_ALLOWED_REDIRECT_URIS={}
# AUTH_CORS_ORIGINS=

# ============================================================
# Default configuration for this setting.
# ============================================================
# FRONTEND_PORT=80
# FRONTEND_API_BASE_URL=/api
# VITE_ALLOWED_REDIRECT_ORIGINS=

SIDECAR_URL=http://127.0.0.1:8001
SIDECAR_API_KEY=CHANGE_ME
# KNOWLEDGE_BASE_URL=http://knowledge-base-service:8000

# ============================================================
# LLM, embedding configuration for LLMGW UPSTREAM LLM API KEY.
# ============================================================
# LLMGW_UPSTREAM_LLM_HOST=https://tokenhub.tencentmaas.com/v1
LLMGW_UPSTREAM_LLM_API_KEY=
# LLMGW_UPSTREAM_EMBED_HOST=http://host.docker.internal:11434/v1
# LLMGW_UPSTREAM_EMBED_API_KEY=ollama
# LLMGW_INTERNAL_TOKENS=CHANGE_ME_LIGHTRAG,CHANGE_ME_PLATFORM
# LLMGW_METERING_ENABLED=true
# ===== Configuration note for LLMGW DISABLE THINKING ENABLED =====
# Sensitive configuration for LLMGW DISABLE THINKING ENABLED; use a securely generated environment-specific value.
# Configuration note for LLMGW DISABLE THINKING ENABLED.
# gateway, model configuration for LLMGW DISABLE THINKING ENABLED.
# LLM, ontology configuration for LLMGW DISABLE THINKING ENABLED.
LLMGW_DISABLE_THINKING_ENABLED=true
LLMGW_DISABLE_THINKING_MODELS=deepseek-v4-flash-202605
LLMGW_DISABLE_THINKING_SCENES=lightrag_extract,ontology_extract

# ============================================================
# LLM, ontology configuration for ONTOLOGY EXTRACT ENABLED.
# ============================================================
ONTOLOGY_EXTRACT_ENABLED=true
# Default configuration for ONTOLOGY SCHEMA PATH.
ONTOLOGY_SCHEMA_PATH=deploy/config/ontology/default.yaml
# Default configuration for ONTOLOGY ENTITY DESC MAXLEN.
ONTOLOGY_ENTITY_DESC_MAXLEN=1000
# Configuration note for ONTOLOGY KEEP UNTYPED EDGES.
ONTOLOGY_KEEP_UNTYPED_EDGES=true
# Default configuration for ONTOLOGY ROUTE SCORE MIN.
# Configuration note for ONTOLOGY ROUTE SCORE MIN.
ONTOLOGY_ROUTE_SCORE_MIN=1.0
# Default configuration for REASONING TRACE ENABLED.
REASONING_TRACE_ENABLED=true
# LLM, ontology configuration for LLM BINDING API KEY FOR ONTOLOGY.
LLM_BINDING_API_KEY_FOR_ONTOLOGY=

# ============================================================
# LightRAG, RAG configuration for LIGHTRAG API KEY.
# ============================================================
# Sensitive configuration for LIGHTRAG API KEY; use a securely generated environment-specific value.
LIGHTRAG_API_KEY=change-me-in-production-please
# Configuration note for RAG WEBHOOK URL.
RAG_WEBHOOK_URL=
# LightRAG, RAG configuration for RAG MIN QUERY LEN.
RAG_MIN_QUERY_LEN=3

# ============================================================
# parser configuration for RAG PARSER.
# ------------------------------------------------------------
# RAG configuration for RAG PARSER.
# Configuration note for RAG PARSER.
# ============================================================
RAG_PARSER=mineru_selfhost

# network, parser configuration for MINERU PARSE MAX RETRIES.
MINERU_PARSE_MAX_RETRIES=3
MINERU_PARSE_RETRY_BACKOFF=3

# ===== Configuration note for MINERU MODEL SOURCE =====
# Proxy and routing configuration for MINERU MODEL SOURCE.
# RAG, backend configuration for MINERU MODEL SOURCE.
MINERU_MODEL_SOURCE=modelscope

# ===== Configuration note for MINERU SELFHOST BASE URL =====
MINERU_SELFHOST_BASE_URL=http://127.0.0.1:8000
MINERU_SELFHOST_BACKEND=pipeline
MINERU_SELFHOST_LANG=ch
MINERU_SELFHOST_POLL_INTERVAL=5
MINERU_SELFHOST_POLL_TIMEOUT=1800
MINERU_SELFHOST_RETURN_IMAGES=false

# ===== Configuration note for MINERU API TOKEN =====
MINERU_API_TOKEN=
MINERU_API_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL=5
MINERU_POLL_TIMEOUT=1800

# ============================================================
# Configuration note for MPS ENABLED.
# ============================================================
# object storage, storage, parser configuration for MPS ENABLED.
MPS_ENABLED=true
MPS_SECRET_ID=
MPS_SECRET_KEY=
MPS_REGION=ap-guangzhou
MPS_COS_BUCKET=your-cos-bucket-1234567890
MPS_COS_REGION=ap-guangzhou
MPS_DEFINITION=33
MPS_TIMEOUT=600
MPS_POLL_INTERVAL=3
MPS_MAX_RETRIES=3
MPS_PROMPT_CATEGORY=mps_scene_description

# ============================================================
# object storage, storage configuration for OBJECT STORAGE BACKEND.
# ============================================================
OBJECT_STORAGE_BACKEND=cos
COS_KEY_PREFIX=jonex
COS_REGION=ap-guangzhou
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=your-cos-bucket-1234567890
COS_PRESIGN_EXPIRES=900

# ============================================================
# Configuration note for this setting.
# ============================================================
# Required configuration for this setting; provide an environment-specific value.
# DATA_SOURCE_SECRET_KEY=
# Configuration note for AUDIT LOG ENABLED.
# PUBLIC_API_BASE=http://localhost

# ============================================================
# logging configuration for AUDIT LOG ENABLED.
# ============================================================
AUDIT_LOG_ENABLED=true
AUDIT_INGEST_URL=http://127.0.0.1:8006
# AUDIT_LOG_ASYNC=true
# AUDIT_QUEUE_MAX_SIZE=10000
# AUDIT_FLUSH_BATCH_SIZE=100
# AUDIT_FLUSH_INTERVAL_MS=200
# AUDIT_RETENTION_DAYS=90
# AUDIT_HTTP_METHODS=POST,PUT,PATCH,DELETE

# ============================================================
# Optional configuration for TCADP API URL.
# ============================================================
TCADP_API_URL=https://tcadp.tencent.com/api
TCADP_API_KEY=your_tcadp_api_key_here
TCADP_WEBHOOK_SECRET=your_webhook_secret
