# ============================================================
# Development-only configuration for this setting.
# ============================================================
# Sidecar, backend configuration for this setting.
# PostgreSQL, Redis, Neo4j configuration for this setting.
#
# Configuration note for this setting.
# Copy the required files into the image.
#        Copy-Item .env.server-local.example .env
# Configuration note for this setting.
# frontend, backend configuration for this setting.
#
# Configuration note for this setting.
# Port configuration for this setting.
# LLM configuration for DB HOST.
# Development-only configuration for DB HOST.
# ============================================================

# ============================================================
# PostgreSQL configuration for DB HOST.
# ============================================================
DB_HOST=SERVER_IP
DB_PORT=5432
DB_USERNAME=jonex
DB_PASSWORD=CHANGE_ME
DB_NAME=jonex

# ============================================================
# Redis configuration for REDIS URL.
# ============================================================
REDIS_URL=redis://SERVER_IP:6379/0

# ============================================================
# Milvus configuration for MILVUS HOST.
# ============================================================
MILVUS_HOST=SERVER_IP
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_HTTP_PORT=9091

# MinIO, Milvus configuration for MINIO ADDRESS.
MINIO_ADDRESS=SERVER_IP:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# Milvus, etcd configuration for ETCD ENDPOINTS.
ETCD_ENDPOINTS=SERVER_IP:2379

# ============================================================
# Neo4j configuration for NEO4J URI.
# ============================================================
NEO4J_URI=bolt://SERVER_IP:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ============================================================
# Development-only configuration for JWT SECRET.
# ============================================================
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
JWT_INTERNAL_SECRET=your_internal_jwt_secret_here

# ============================================================
# logging configuration for LOG LEVEL.
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Configuration note for SIDECAR URL.
# ============================================================
SIDECAR_URL=http://localhost:8001
SIDECAR_API_KEY=CHANGE_ME
PLATFORM_URL=http://localhost:8006
KNOWLEDGE_BASE_URL=http://localhost:8003
BUSINESS_DOMAIN_URL=http://localhost:8005
ATOMIC_RAG_URL=http://localhost:8004

# ============================================================
# LLM Gateway
# LLM configuration for this setting.
# LLM configuration for this setting.
# Configuration note for this setting.
# ============================================================
# LLMGW_UPSTREAM_LLM_HOST=https://api.tokenhub.tencent.com/v1
# LLMGW_UPSTREAM_LLM_API_KEY=your_tokenhub_api_key

# LLM configuration for this setting.
# Development-only configuration for this setting.
# Configuration note for this setting.
# LLM_GATEWAY_HOST=127.0.0.1
# LLM_GATEWAY_PORT=8787

# ============================================================
# Development-only configuration for this setting.
# ============================================================
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_ASYNC=true

# ============================================================
# Development-only configuration for OBJECT STORAGE BACKEND.
# ============================================================
OBJECT_STORAGE_BACKEND=local

# ============================================================
# Development-only configuration for AUTH ALLOWED REDIRECT URIS.
# ============================================================
AUTH_ALLOWED_REDIRECT_URIS={}
# AUTH_CORS_ORIGINS=
LOGIN_TICKET_EXPIRE_SECONDS=60

# ============================================================
# Development-only configuration for PUBLIC API BASE.
# ============================================================
PUBLIC_API_BASE=http://localhost

# ============================================================
# Optional configuration for TCADP API URL.
# ============================================================
TCADP_API_URL=https://tcadp.tencent.com/api
TCADP_API_KEY=your_tcadp_api_key_here
TCADP_WEBHOOK_SECRET=your_webhook_secret
