{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@jonex/platform-theme": ["../shared/platform-theme/src/index.ts"],
      "@jonex/platform-theme/*": ["../shared/platform-theme/src/*"],
      "@jonex/shell-sdk": ["../shared/shell-sdk/src/index.ts"]
    },

  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
