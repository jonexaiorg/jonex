# ============================================================
# Jonex Dev Gateway — Environment Variables
# ============================================================
# Copy this file to .env and adjust as needed.

# Gateway listen port
GATEWAY_PORT=8080

# Backend API gateway
API_TARGET=http://localhost:8000

# Frontend Vite dev servers
SHELL_TARGET=http://localhost:5173
CORE_BUSINESS_TARGET=http://localhost:5175
ECOSYSTEM_MANAGEMENT_TARGET=http://localhost:5176
PLATFORM_MANAGEMENT_TARGET=http://localhost:5177
