# ==============================
# Jonex平台环境配置文件
# 复制为 .env 并修改为实际值
# ==============================

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=jonex

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Milvus 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_HTTP_PORT=9091

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# TCADP 平台配置
TCADP_API_URL=https://tcadp.tencent.com/api
TCADP_API_KEY=your_tcadp_api_key_here

# 本体抽取配置（知识库文档上传后，是否自动抽取结构化本体到 ontology.entities / ontology.relations 表）
# ONTOLOGY_EXTRACT_ENABLED=true

# 日志配置
LOG_LEVEL=INFO
